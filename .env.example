# ===========================================
# Discord Compensation Bot - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit your .env file to version control
# ===========================================

# Discord Bot Configuration
# Get your bot token from https://discord.com/developers/applications
# Bot > Token > "Reset Token" (copy the token)
DISCORD_TOKEN=your_bot_token_here

# Your Application ID (Client ID)
# Found in Developer Portal > General > Application ID
CLIENT_ID=your_application_id_here

# Your Server ID (Guild ID)
# Right-click your server > Copy ID (Developer Mode must be enabled)
GUILD_ID=your_test_guild_id_here

# ===========================================
# Admin Configuration
# ===========================================

# Your Discord User ID (Bot Owner)
# Right-click your username > Copy ID (Developer Mode must be enabled)
# This user has full access to all commands
OWNER_ID=your_discord_user_id

# Admin Role ID (Optional)
# Right-click the role > Copy ID (Developer Mode must be enabled)
# Users with this role can use admin commands
ADMIN_ROLE_ID=admin_role_id

# ===========================================
# Database Configuration
# ===========================================

# Path to SQLite database file
# Default: ./compensation_tickets.db
# The database will be created automatically if it doesn't exist
DATABASE_PATH=./compensation_tickets.db

# ===========================================
# Logging Configuration
# ===========================================

# Log level: error, warn, info, debug
# Default: info
LOG_LEVEL=info

# ===========================================
# How to get your Discord IDs:
# ===========================================
# 1. Enable Developer Mode in Discord:
#    Settings > Advanced > Developer Mode (toggle on)
# 2. Copy IDs by right-clicking and selecting "Copy ID"
# 3. Bot Token: Get from Developer Portal
# 4. Application ID: Get from Developer Portal > General
# 5. Guild ID: Right-click server > Copy ID
# 6. User ID: Right-click username > Copy ID
# 7. Role ID: Right-click role > Copy ID

# ===========================================
# Quick Start:
# ===========================================
# 1. Create a Discord Application at https://discord.com/developers/applications
# 2. Create a bot user and get the token
# 3. Enable necessary bot permissions and scopes
# 4. Fill in the values above
# 5. Run: npm install && npm run build && npm start
# 6. Use /setup_compensation in your server to configure the bot